{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for authentication and role management",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "coach", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Coach": {
      "title": "Coach",
      "description": "Coach specific profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "img": { "type": "string", "format": "uri" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "specialty": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "Client": {
      "title": "Client",
      "description": "Client profile with health targets and coach assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "img": { "type": "string", "format": "uri" },
        "program": { "type": "string" },
        "status": { "type": "string" },
        "active": { "type": "boolean" },
        "weight": { "type": "string" },
        "targetWeight": { "type": "number" },
        "bodyFat": { "type": "string" },
        "stepsTarget": { "type": "number" },
        "waterTarget": { "type": "number" },
        "assignedCoachId": { "type": "string" },
        "dietType": { "type": "string" },
        "allergies": { "type": "string" },
        "enabledSections": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "assignedCoachId"]
    },
    "DailyLog": {
      "title": "DailyLog",
      "description": "Daily health and activity tracking for a client",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "weight": { "type": "number" },
        "sleepHours": { "type": "number" },
        "sleepQuality": { "type": "string", "enum": ["Mal", "Regular", "Bien", "Excelente"] },
        "waterCompleted": { "type": "boolean" },
        "stepsCompleted": { "type": "number" },
        "kcalConsumed": { "type": "number" }
      },
      "required": ["clientId", "date"]
    },
    "Diet": {
      "title": "Diet",
      "description": "Diet plan for a client",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "pdfUrl": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/coaches/{coachId}": {
      "schema": "Coach",
      "description": "Coach profiles"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Client profiles"
    },
    "/clients/{clientId}/logs/{logId}": {
      "schema": "DailyLog",
      "description": "Daily tracking logs for clients"
    },
    "/clients/{clientId}/diets/{dietId}": {
      "schema": "Diet",
      "description": "Diet plans for clients"
    }
  }
}
