rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (enum: 'admin', 'coach', 'client') (required)
    //   - createdAt: timestamp (required)
    //   - active: bool (optional)
    //
    // Collection: coaches
    // Document ID: coachId
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - img: string (optional)
    //   - phone: string (optional)
    //
    // Collection: clients
    // Document ID: clientId
    // Fields:
    //   - name: string (required)
    //   - assignedCoachId: string (required)
    //   - active: bool (optional)
    //   - targetWeight: number (optional)
    //   - dietType: string (optional)
    //   - allergies: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.uid == "cNznYermOtdOG7CSdHG9xZZ19tU2") ||
        (request.auth.token.email == "admin@admin.com") ||
        (request.auth.token.email == "alvarowowplayer@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isCoach() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAssignedCoach(clientId) {
      let client = get(/databases/$(database)/documents/clients/$(clientId)).data;
      return isAuthenticated() && request.auth.uid == client.assignedCoachId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
             data.email is string &&
             data.name is string &&
             data.role in ['admin', 'coach', 'client'] &&
             data.createdAt is timestamp;
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'assignedCoachId']) &&
             data.name is string &&
             data.assignedCoachId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Global Admin Bypass
    match /{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == "cNznYermOtdOG7CSdHG9xZZ19tU2" ||
        request.auth.token.email == "admin@admin.com"
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isCoach());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || isCoach());
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    // Coaches collection
    match /coaches/{coachId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isAuthenticated() && (isOwner(clientId) || isAdmin() || isAssignedCoach(clientId));
      allow create: if isAuthenticated() && isValidClient(request.resource.data) && (isAdmin() || isCoach());
      allow update: if isAuthenticated() && (isAdmin() || isAssignedCoach(clientId) || isOwner(clientId));
      
      // Subcollections for clients
      match /logs/{logId} {
        allow read, write: if isAuthenticated() && (isOwner(clientId) || isAdmin() || isAssignedCoach(clientId));
      }
      
      match /diets/{dietId} {
        allow read: if isAuthenticated() && (isOwner(clientId) || isAdmin() || isAssignedCoach(clientId));
        allow write: if isAuthenticated() && (isAdmin() || isAssignedCoach(clientId));
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (resource != null && (resource.data.assignedCoachId == request.auth.uid || resource.data.clientId == request.auth.uid))
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource != null && (resource.data.assignedCoachId == request.auth.uid || resource.data.clientId == request.auth.uid))
      );
      allow delete: if isAuthenticated() && (
        isAdmin() || 
        (resource != null && resource.data.assignedCoachId == request.auth.uid)
      );
    }
  }
}
